# SPDX-License-Identifier: Apache-2.0
# Nexus API — Kubernetes Secret template
#
# USAGE
#   1. Copy to api-secret.yaml (gitignored)
#   2. Fill in real values (base64-encode each):
#        echo -n "value" | base64
#   3. Apply:
#        kubectl apply -f infra/k8s/api-secret.yaml -n nexus
#
# Or use Sealed Secrets / External Secrets Operator:
#   helm install sealed-secrets \
#     sealed-secrets/sealed-secrets -n kube-system
#
# REQUIRED secrets — the API will refuse to start without these in prod:
#   NEXUS_API_KEY       random hex, ≥32 chars  (gateway bearer token)
#   NEXUS_JWT_SECRET    random hex, ≥32 chars  (JWT signing key)
#   DATABASE_URL        Neon connection string  (sslmode=require)
#   GROQ_API_KEY        from console.groq.com
#
# OPTIONAL secrets — feature-gated; service degrades gracefully if absent:
#   ANTHROPIC_API_KEY   claude-* models
#   OPENROUTER_API_KEY  openrouter.ai
#   GEMINI_API_KEY      Google Gemini
#   DEEPSEEK_API_KEY    deepseek-chat
#   MISTRAL_API_KEY     mistral-large
#   FIREWORKS_API_KEY   fireworks.ai
#   NVIDIA_API_KEY      NVIDIA NIM
#   CEREBRAS_API_KEY    cerebras.ai
#   KIMI_API_KEY        Moonshot Kimi
#   CODESTRAL_API_KEY   Mistral Codestral
#   OLLAMA_BASE_URL     local Ollama endpoint (default: http://localhost:11434)
#   TAVILY_API_KEY      web search
#   GITHUB_TOKEN        GitHub connector
#   SLACK_BOT_TOKEN     Slack connector
#   LINEAR_API_KEY      Linear connector
#   STRIPE_SECRET_KEY   billing
#   STRIPE_WEBHOOK_SECRET  billing webhooks
#   UPSTASH_REDIS_URL   rate-limit KV store   (format: rediss://...)
#   UPSTASH_REDIS_TOKEN Upstash REST token
#   POSTHOG_API_KEY     product analytics
#   SENTRY_DSN          error tracking
#   NEXUS_JWT_AUDIENCE  JWT audience claim   (optional, default: nexus-api)
#   ALLOWED_ORIGINS     CORS origins comma-separated
#   OAUTH_ENCRYPTION_KEY  32-byte hex for AES-256-GCM credential storage
#   GITHUB_CLIENT_ID    GitHub OAuth app
#   GITHUB_CLIENT_SECRET
#   SLACK_CLIENT_ID     Slack OAuth app
#   SLACK_CLIENT_SECRET
#   LINEAR_CLIENT_ID    Linear OAuth app
#   LINEAR_CLIENT_SECRET
#   OAUTH_REDIRECT_BASE_URL  e.g. https://api.nexus.yashawasthi.dev
---
apiVersion: v1
kind: Secret
metadata:
  name: nexus-api-secrets
  namespace: nexus
  labels:
    app.kubernetes.io/name: nexus
    app.kubernetes.io/component: api
type: Opaque
data:
  # ── Required ────────────────────────────────────────────────────────────────
  NEXUS_API_KEY:         <base64-encoded>
  NEXUS_JWT_SECRET:      <base64-encoded>
  DATABASE_URL:          <base64-encoded>
  GROQ_API_KEY:          <base64-encoded>

  # ── LLM Providers (optional) ─────────────────────────────────────────────
  ANTHROPIC_API_KEY:     <base64-encoded>
  GEMINI_API_KEY:        <base64-encoded>
  OPENROUTER_API_KEY:    <base64-encoded>
  DEEPSEEK_API_KEY:      <base64-encoded>
  MISTRAL_API_KEY:       <base64-encoded>
  FIREWORKS_API_KEY:     <base64-encoded>
  NVIDIA_API_KEY:        <base64-encoded>
  CEREBRAS_API_KEY:      <base64-encoded>
  KIMI_API_KEY:          <base64-encoded>
  CODESTRAL_API_KEY:     <base64-encoded>

  # ── Search ────────────────────────────────────────────────────────────────
  TAVILY_API_KEY:        <base64-encoded>

  # ── Connectors ────────────────────────────────────────────────────────────
  GITHUB_TOKEN:          <base64-encoded>
  SLACK_BOT_TOKEN:       <base64-encoded>
  LINEAR_API_KEY:        <base64-encoded>

  # ── Billing ───────────────────────────────────────────────────────────────
  STRIPE_SECRET_KEY:     <base64-encoded>
  STRIPE_WEBHOOK_SECRET: <base64-encoded>

  # ── KV / Cache ────────────────────────────────────────────────────────────
  UPSTASH_REDIS_URL:     <base64-encoded>
  UPSTASH_REDIS_TOKEN:   <base64-encoded>

  # ── Observability ─────────────────────────────────────────────────────────
  POSTHOG_API_KEY:       <base64-encoded>
  SENTRY_DSN:            <base64-encoded>

  # ── OAuth ─────────────────────────────────────────────────────────────────
  OAUTH_ENCRYPTION_KEY:  <base64-encoded>
  GITHUB_CLIENT_ID:      <base64-encoded>
  GITHUB_CLIENT_SECRET:  <base64-encoded>
  SLACK_CLIENT_ID:       <base64-encoded>
  SLACK_CLIENT_SECRET:   <base64-encoded>
  LINEAR_CLIENT_ID:      <base64-encoded>
  LINEAR_CLIENT_SECRET:  <base64-encoded>
