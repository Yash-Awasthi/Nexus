{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Gateway Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(nexus_gateway_requests_total{status=\"all\"}[5m])",
          "legendFormat": "Total req/s",
          "refId": "A"
        },
        {
          "expr": "rate(nexus_gateway_requests_total{status=\"error\"}[5m])",
          "legendFormat": "Errors/s",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Gateway Latency (last observed)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "nexus_gateway_latency_ms",
          "legendFormat": "Last latency ms",
          "refId": "A"
        },
        {
          "expr": "nexus_slo_p99_latency_ms",
          "legendFormat": "p99 latency ms",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Token Usage (input / output)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "stacking": { "mode": "normal" } }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "nexus_gateway_tokens_total{type=\"input\"}",
          "legendFormat": "Input tokens",
          "refId": "A"
        },
        {
          "expr": "nexus_gateway_tokens_total{type=\"output\"}",
          "legendFormat": "Output tokens",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Cumulative LLM Cost (USD)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "nexus_gateway_cost_usd_total",
          "legendFormat": "Total cost USD",
          "refId": "A"
        }
      ]
    },
    {
      "title": "SLO Availability",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.99 },
              { "color": "green", "value": 0.999 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "nexus_slo_availability",
          "legendFormat": "Availability",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Conductor Job Status",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "fillOpacity": 60 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "nexus_conductor_jobs_total{status=\"done\"}",
          "legendFormat": "Done",
          "refId": "A"
        },
        {
          "expr": "nexus_conductor_jobs_total{status=\"failed\"}",
          "legendFormat": "Failed",
          "refId": "B"
        },
        {
          "expr": "nexus_conductor_jobs_total{status=\"blocked\"}",
          "legendFormat": "Blocked",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Conductor Queue Depth",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 20 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 20 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "nexus_conductor_queue_depth{queue=\"main\"}",
          "legendFormat": "Main queue",
          "refId": "A"
        },
        {
          "expr": "nexus_conductor_queue_depth{queue=\"dead_letter\"}",
          "legendFormat": "Dead letter",
          "refId": "B"
        },
        {
          "expr": "nexus_conductor_queue_depth{queue=\"active\"}",
          "legendFormat": "Active",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Process Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "process_heap_bytes",
          "legendFormat": "Heap used",
          "refId": "A"
        },
        {
          "expr": "process_rss_bytes",
          "legendFormat": "RSS",
          "refId": "B"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["nexus"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "NEXUS_PROMETHEUS" },
        "hide": 0
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Nexus Overview",
  "uid": "nexus-overview",
  "version": 1
}
