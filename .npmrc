engine-strict=true
strict-peer-dependencies=false
auto-install-peers=true
shamefully-hoist=true

# Hoist ESLint and its plugins so packages can find eslint.config.js dependencies
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
# Hoist vitest so adapter/council packages can run tests without per-package devDep
public-hoist-pattern[]=*vitest*
public-hoist-pattern[]=@vitest*
