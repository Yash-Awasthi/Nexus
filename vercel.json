{
  "framework": null,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @nexus/ui build",
  "outputDirectory": "apps/ui/build/client",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://nexus-api-production-4bb9.up.railway.app/api/$1"
    },
    {
      "source": "/health",
      "destination": "https://nexus-api-production-4bb9.up.railway.app/health"
    },
    {
      "source": "/health/(.*)",
      "destination": "https://nexus-api-production-4bb9.up.railway.app/health/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
