{
  "name": "@nexus/skills",
  "version": "0.0.0",
  "private": false,
  "description": "Skills framework — declarative skill definitions, registry, trigger matching (keyword/regex/always), and builtin skills",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
