{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GhostStackArtifact",
  "type": "object",
  "properties": {
    "artifact_id": { "type": "string" },
    "name": { "type": "string" },
    "path": { "type": "string" },
    "file_size_bytes": { "type": "integer", "minimum": 0 },
    "sha256_checksum": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "mime_type": { "type": "string" },
    "created_by_task_id": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "artifact_id",
    "name",
    "path",
    "file_size_bytes",
    "sha256_checksum",
    "created_by_task_id",
    "created_at"
  ]
}
