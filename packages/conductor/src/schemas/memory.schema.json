{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GhostStackMemoryRecord",
  "type": "object",
  "properties": {
    "memory_id": { "type": "string" },
    "type": {
      "type": "string",
      "enum": ["episodic", "semantic", "architectural"]
    },
    "content": { "type": "string" },
    "associated_task_id": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "embedding_vector": {
      "type": "array",
      "items": { "type": "number" }
    }
  },
  "required": ["memory_id", "type", "content", "timestamp"]
}
