{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GhostStackWorkflowSpec",
  "type": "object",
  "properties": {
    "spec_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+$"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "author": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "template_id": { "type": "string" },
    "variables": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "type": {
            "type": "string",
            "enum": [
              "floci",
              "scraping",
              "browser",
              "search",
              "answer",
              "web_search",
              "code_explore",
              "file_picker",
              "code_edit",
              "edit",
              "code_review",
              "review",
              "research",
              "web_research",
              "reason",
              "think",
              "inference",
              "local_llm",
              "generate",
              "custom"
            ]
          },
          "action": { "type": "string" },
          "priority": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
          "arguments": { "type": "object" },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["id", "title", "type", "action"]
      }
    },
    "phases": {
      "description": "Spec-driven development phases (spec-kit compatible)",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "task_ids": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["name", "task_ids"]
      }
    },
    "acceptance_criteria": {
      "description": "Verifiable completion conditions for the workflow (spec-kit compatible)",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "type": { "type": "string", "enum": ["output", "side_effect", "assertion", "manual"] },
          "check": { "type": "string" }
        },
        "required": ["id", "description"]
      }
    },
    "constraints": {
      "description": "Governance constraints applied to this workflow",
      "type": "object",
      "properties": {
        "max_cost_usd": { "type": "number" },
        "max_runtime_ms": { "type": "number" },
        "require_approval": { "type": "boolean" },
        "allowed_resource_scopes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "required": ["spec_version", "metadata", "template_id", "tasks"]
}
