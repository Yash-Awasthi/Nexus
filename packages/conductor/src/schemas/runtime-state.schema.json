{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GhostStackRuntimeState",
  "type": "object",
  "properties": {
    "engine_version": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["idle", "running", "paused", "failed", "stopped"]
    },
    "active_worker_threads": { "type": "integer", "minimum": 0 },
    "last_heartbeat": { "type": "string", "format": "date-time" },
    "registered_nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "node_id": { "type": "string" },
          "role": { "type": "string" },
          "ip_address": { "type": "string" },
          "port": { "type": "integer" }
        },
        "required": ["node_id", "role"]
      }
    },
    "queue_metrics": {
      "type": "object",
      "properties": {
        "jobs_in_buffer": { "type": "integer", "minimum": 0 },
        "jobs_succeeded": { "type": "integer", "minimum": 0 },
        "jobs_failed": { "type": "integer", "minimum": 0 }
      },
      "required": ["jobs_in_buffer", "jobs_succeeded", "jobs_failed"]
    },
    "governance_metrics": {
      "type": "object",
      "properties": {
        "pending_approval_count": { "type": "integer", "minimum": 0 },
        "approved_count": { "type": "integer", "minimum": 0 },
        "rejected_count": { "type": "integer", "minimum": 0 }
      },
      "required": ["pending_approval_count", "approved_count", "rejected_count"]
    }
  },
  "required": [
    "engine_version",
    "status",
    "active_worker_threads",
    "last_heartbeat",
    "queue_metrics"
  ]
}
