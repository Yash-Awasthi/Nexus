{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GhostStackTask",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "type": { "type": "string" },
    "action": { "type": "string" },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "status": { "type": "string" },
    "arguments": {
      "type": "object",
      "additionalProperties": true
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": ["id", "title"]
}
