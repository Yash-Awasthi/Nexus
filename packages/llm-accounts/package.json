{
  "name": "@nexus/llm-accounts",
  "version": "0.0.0",
  "private": false,
  "description": "Multi-account pool + tier ladder for LLM providers — N creds per provider with health/cooldown/quota state, tier-aware routing (sub→cheap→free), and a per-account circuit breaker.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
