{
  "name": "@nexus/runtime",
  "version": "0.1.0",
  "private": false,
  "description": "Execution kernel (ex-GhostStack): planning, governance, task execution, circuit breaker, queues",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@nexus/governance": "workspace:*",
    "@nexus/memory": "workspace:*",
    "@nexus/telemetry": "workspace:*",
    "bullmq": "^5.34.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@fast-check/vitest": "^0.1.5",
    "@types/js-yaml": "^4.0.9",
    "fast-check": "^3.23.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
