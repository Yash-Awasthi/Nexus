{
  "name": "@nexus/root",
  "private": true,
  "version": "0.0.0",
  "description": "NEXUS — AI orchestration platform (monorepo root)",
  "packageManager": "pnpm@9.14.4",
  "engines": {
    "node": ">=20.18.0",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:spectre": "pnpm --filter @nexus/spectre dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:e2e": "turbo run test:e2e",
    "test:a11y": "turbo run test:a11y",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md,yaml,yml}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,md,yaml,yml}\" --ignore-path .prettierignore",
    "clean": "turbo run clean && find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
    "generate": "tsx scripts/generate-clients.ts",
    "db:migrate": "turbo run db:migrate --filter @nexus/db",
    "db:generate": "turbo run db:generate --filter @nexus/db",
    "docs:check": "turbo run docs:check",
    "check:headers": "tsx scripts/check-license-headers.ts",
    "sbom": "syft . -o cyclonedx-json > sbom.json",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "prune:knip": "knip",
    "prune:madge": "madge packages/ apps/ --warning",
    "prune:depcheck": "depcheck"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.7",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@eslint/js": "^9.13.0",
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^2.1.4",
    "vitest": "^2.1.9",
    "depcheck": "^1.4.7",
    "eslint": "^9.13.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-promise": "^7.1.0",
    "eslint-plugin-vitest": "^0.5.4",
    "husky": "^9.1.6",
    "knip": "^5.33.0",
    "lint-staged": "^15.2.10",
    "madge": "^8.0.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.11.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs}": [
      "eslint --fix --quiet",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}
