NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# ── Redis (BullMQ) ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── API Server ────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
ALLOWED_ORIGINS=http://localhost:5173
LOG_LEVEL=info
LOG_FORMAT=pretty

# ── Auth ──────────────────────────────────────────────────────────────────────
NEXUS_API_KEY=your-api-key-here
NEXUS_AUDIT_KEY=your-audit-key-here
NEXUS_INGEST_API_KEY=your-ingest-key-here

# ── AI providers — cloud ──────────────────────────────────────────────────────
# At least one must be set. GROQ_API_KEY is free and recommended for dev.
GROQ_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=
FIREWORKS_API_KEY=
NVIDIA_NIM_API_KEY=
CEREBRAS_API_KEY=
KIMI_API_KEY=
TAVILY_API_KEY=

# ── AI providers — local (optional) ──────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
LM_STUDIO_BASE_URL=
LLAMA_CPP_BASE_URL=

# ── HuggingFace ───────────────────────────────────────────────────────────────
HF_TOKEN=

# ── Observability ─────────────────────────────────────────────────────────────
BRAINTRUST_API_KEY=
POSTHOG_API_KEY=
NEXUS_TRACING=false

# ── External data feeds ───────────────────────────────────────────────────────
GEOIP_DB_PATH=/var/lib/geoip/GeoLite2-City.mmdb
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
POLYMARKET_BASE_URL=https://clob.polymarket.com

# ── Web (Vite) ────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000
VITE_API_KEY=your-api-key-here
