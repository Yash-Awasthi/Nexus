# SPECTRE — environment variables
# Copy to .env: cp .env.example .env

# URL of the running Nexus API (apps/api).
# Leave empty — Vite dev server proxies /api and /health to localhost:3000 automatically.
# Set this only for production builds pointing at a remote API.
# VITE_API_URL=https://api.your-nexus-instance.com

# API key — matches NEXUS_API_KEY in the root Nexus .env
# VITE_API_KEY=your-nexus-api-key
