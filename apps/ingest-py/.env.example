# Nexus API connection
NEXUS_API_URL=http://localhost:3000
NEXUS_INGEST_API_KEY=your-nexus-api-key-here

# fin-scrape output directory (*.json files written by the scraper)
FINSCRAPE_OUTPUT_DIR=/data/finscrape
FINSCRAPE_DONE_DIR=/data/finscrape/done

# Optional: protect the bridge's own /push and /scan endpoints
BRIDGE_API_KEY=

# Server
BRIDGE_PORT=8001
LOG_LEVEL=info
