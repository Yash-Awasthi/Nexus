{
  "name": "@workspace/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build":     "tsc -p tsconfig.json",
    "dev":       "tsx watch src/index.ts",
    "start":     "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean":     "rm -rf dist"
  },
  "dependencies": {
    "@workspace/core":              "workspace:*",
    "@workspace/integrations":      "workspace:*",
    "@workspace/orchestrator":      "workspace:*",
    "@workspace/agent-researcher":  "workspace:*",
    "@workspace/agent-coder":       "workspace:*",
    "@workspace/agent-github":      "workspace:*",
    "@workspace/agent-slack":       "workspace:*",
    "@workspace/agent-linear":      "workspace:*",
    "@workspace/agent-deploy":      "workspace:*",
    "@workspace/agent-database":    "workspace:*",
    "@workspace/agent-secrets":     "workspace:*",
    "@workspace/agent-email":       "workspace:*",
    "@workspace/agent-calendar":    "workspace:*",
    "@workspace/agent-drive":       "workspace:*",
    "@workspace/agent-content":     "workspace:*",
    "@workspace/agent-analyst":     "workspace:*",
    "@workspace/agent-monitor":     "workspace:*",
    "@workspace/agent-scheduler":   "workspace:*",
    "@workspace/agent-memory":      "workspace:*",
    "@workspace/agent-orchestrator":"workspace:*",
    "@workspace/agent-yash":        "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx":         "^4.0.0",
    "typescript":  "^5.5.0"
  }
}
