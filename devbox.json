{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.13.7/.schema/devbox.schema.json",
  "name": "nexus",
  "description": "Nexus monorepo — reproducible development environment",
  "packages": {
    "nodejs_20": "latest",
    "nodePackages.pnpm": "latest",
    "python311": "latest",
    "git": "latest",
    "docker": "latest",
    "docker-compose": "latest"
  },
  "env": {
    "NODE_ENV": "development",
    "PATH": "$PWD/node_modules/.bin:$PATH"
  },
  "shell": {
    "init_hook": [
      "echo 'Nexus dev shell ready. Run: devbox run install && devbox run build'"
    ],
    "scripts": {
      "install":   "pnpm install",
      "build":     "pnpm build",
      "dev":       "pnpm dev",
      "test":      "pnpm test",
      "lint":      "pnpm lint",
      "typecheck": "pnpm typecheck",
      "format":    "pnpm format",
      "db:up":     "docker compose up -d postgres redis",
      "stack:up":  "docker compose up -d",
      "stack:down": "docker compose down"
    }
  }
}
