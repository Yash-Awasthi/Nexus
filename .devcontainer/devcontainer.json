{
  "name": "NEXUS",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:20",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "forwardPorts": [3001, 5173, 3000, 4173, 5432, 6379],
  "portsAttributes": {
    "3001": { "label": "API (dev)" },
    "5173": { "label": "UI (dev)" },
    "5432": { "label": "Postgres" },
    "6379": { "label": "Redis" }
  },
  "onCreateCommand": "corepack enable && corepack prepare pnpm@9.14.4 --activate",
  "postCreateCommand": "pnpm install && cp -n .env.example .env || true",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
      }
    }
  },
  "remoteUser": "node"
}
