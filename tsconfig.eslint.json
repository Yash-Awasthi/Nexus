// tsconfig used exclusively by ESLint's project-service (not tsc builds).
// Includes test files so @typescript-eslint can type-check them without
// requiring each package to widen its own tsconfig.
{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "scripts/**/*"
  ]
}
