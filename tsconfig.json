{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "lib": ["es2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "types": ["jest", "node"]
  },
  "include": ["orchestration/**/*", "runtime/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist", "coverage"]
}
