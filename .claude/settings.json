{
  "model": "opus",
  "permissions": {
    "allow": [
      "Bash(pnpm install)",
      "Bash(pnpm --filter:*)",
      "Bash(pnpm build)",
      "Bash(pnpm test:*)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm format:*)",
      "Bash(turbo run:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(docker compose:*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Read(.env)",
      "Read(.env.*)"
    ]
  }
}
