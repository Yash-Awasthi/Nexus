# =============================================================================
# Workspace — Environment Variables
# Copy to .env and fill in your values
# Secrets should be managed via Doppler in production
# =============================================================================

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ──────────────────────────────────────────────────────────────────
# Neon Postgres (direct connection for migrations and long-running queries)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
# Neon pooler (for application/serverless connections)
DATABASE_POOL_URL=postgresql://user:pass@pooler-host/db?sslmode=require&channel_binding=require

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_KEY=eyJhbGci...

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=your-username

# ── Groq ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...

# ── Tavily ────────────────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-dev-...

# ── Linear ────────────────────────────────────────────────────────────────────
LINEAR_API_KEY=lin_api_...

# ── Cloudflare ────────────────────────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=...
CLOUDFLARE_ACCOUNT_ID=...

# ── Vercel ────────────────────────────────────────────────────────────────────
VERCEL_TOKEN=...
VERCEL_TEAM_ID=team_...  # optional, for team accounts

# ── Doppler ───────────────────────────────────────────────────────────────────
DOPPLER_TOKEN=dp.st.prd....

# ── Better Stack ──────────────────────────────────────────────────────────────
BETTER_STACK_API_KEY=...
BETTER_STACK_SOURCE_TOKEN=...  # for log ingestion

# ── Google (OAuth2) ───────────────────────────────────────────────────────────
# Required for Gmail, Google Calendar, and Google Drive integrations
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
# Refresh token obtained after OAuth flow
GOOGLE_REFRESH_TOKEN=1//...

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
PORT=3000
