{
  "name": "workspace",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "build":      "turbo run build",
    "dev":        "turbo run dev --filter=@workspace/server",
    "start":      "node apps/server/dist/index.js",
    "lint":       "turbo run lint",
    "typecheck":  "turbo run typecheck",
    "clean":      "turbo run clean",
    "db:migrate": "tsx db/migrate.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx":         "^4.0.0",
    "turbo":       "^2.0.0",
    "typescript":  "^5.5.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
