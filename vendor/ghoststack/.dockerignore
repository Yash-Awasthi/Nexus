# GhostStack .dockerignore

# Dependencies
node_modules/
.git/

# Runtime data
data-runtime/
temp-*/
logs/
backups/

# Build output (we rebuild inside Docker)
dist/

# OS artifacts
.DS_Store
Thumbs.db
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo

# Docs & archives (not needed in runtime image)
docs/
archive/
*.html
*.md

# Vendored apps (not wired into runtime)
apps/

# Environment files (use --env-file or env vars)
.env
.env.example
ghoststack.config.json
