# GhostStack Runtime Configuration Example

# Storage Paths (must resolve inside the repository root when relative)
GHOSTSTACK_DATA_DIR=./data-runtime
GHOSTSTACK_LOG_DIR=./logs

# Floci emulator (see ghoststack_dossier.html — structural keystone on :4566)
GHOSTSTACK_FLOCI_URL=http://localhost:4566
# When true: require live Floci (/health); never return mock success on failures
GHOSTSTACK_FLOCI_STRICT=false
# Allow mocked Floci responses when emulator is down (default follows GHOSTSTACK_OFFLINE_MODE)
GHOSTSTACK_FLOCI_MOCK_FALLBACK=true

# Discovery / API
GHOSTSTACK_API_PORT=3000
GHOSTSTACK_METRICS_PORT=9090

# AWS Execution Adapter (Safe Placeholders Only)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=placeholder_access_key
AWS_SECRET_ACCESS_KEY=placeholder_secret_key

# Ollama Endpoint
OLLAMA_BASE_URL=http://localhost:11434

# MCP / Remote Execution
MCP_REGISTRY_PATH=./schemas/mcp_registry.json

# Runtime mode
GHOSTSTACK_OFFLINE_MODE=true
GHOSTSTACK_BOOTSTRAP_SHOWCASE=false
GHOSTSTACK_BACKUP_ON_START=false

# MCP composite (in-process bridge on server start; external FastMCP via gs start:federation)
GHOSTSTACK_MCP_BRIDGE=1
GHOSTSTACK_API_URL=http://127.0.0.1:3000
GHOSTSTACK_MCP_PORT=8100
GHOSTSTACK_PYTHON=python
GHOSTSTACK_FLOCI_AUTOSTART=true
GHOSTSTACK_MCP_EXTERNAL=true

# Copy ghoststack.config.example.json → ghoststack.config.json to customize ports/features

# Feature Flags
ENABLE_TELEMETRY=true
ENABLE_AUTO_APPROVALS=false
