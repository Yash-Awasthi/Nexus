# ─────────────────────────────────────────────────────────────────────────────
# NEXUS — environment variable reference
#
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────────────────────────

NODE_ENV=development

# PostgreSQL connection string (used by @nexus/db, apps/api, services/ingest)
DATABASE_URL=postgresql://nexus:nexus_dev_password@localhost:5432/nexus

# Redis connection string (used by apps/api BullMQ queues, worker)
REDIS_URL=redis://localhost:6379

# ── API Server ────────────────────────────────────────────────────────────────

# Fastify listen port (default: 3000)
PORT=3000

# Fastify listen host (default: 0.0.0.0)
HOST=0.0.0.0

# Comma-separated allowed CORS origins (default: *)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Log level: trace | debug | info | warn | error | fatal (default: info)
LOG_LEVEL=info

# Log format: json | pretty (default: pretty in dev)
LOG_FORMAT=pretty

# Log file path (optional; if unset logs go to stdout only)
# LOG_FILE=/var/log/nexus/api.log

# ── OpenTelemetry ─────────────────────────────────────────────────────────────

# OTLP collector endpoint (e.g. http://localhost:4318)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Service name tag sent with every trace (default: nexus-runtime)
OTEL_SERVICE_NAME=nexus-runtime

# Sampler: always_on | always_off | traceidratio (default: always_on)
OTEL_TRACES_SAMPLER=always_on

# Sample ratio when using traceidratio (0.0–1.0, default: 1.0)
OTEL_TRACES_SAMPLER_ARG=1.0

# ── Authentication ────────────────────────────────────────────────────────────

# Master API key required in Authorization: Bearer <key> header for all routes
# Generated automatically by: make setup
NEXUS_API_KEY=change-me-dev-api-key

# Separate audit-log signing key (used by GET /audit/verify)
# Generated automatically by: make setup
NEXUS_AUDIT_KEY=change-me-dev-audit-key

# Ingest-only key for POST /ingest/* (can be same as NEXUS_API_KEY)
# Generated automatically by: make setup
NEXUS_INGEST_API_KEY=change-me-dev-ingest-key

# ── AI / LLM providers ────────────────────────────────────────────────────────

# Groq — used by council deliberation engine
GROQ_API_KEY=gsk_...

# Tavily — used by deep-research tasks
TAVILY_API_KEY=tvly-...

# ── Ghoststack adapter ────────────────────────────────────────────────────────

# Base URL of the Ghoststack API (used by packages/adapters ghoststack adapter)
GHOSTSTACK_API_URL=http://localhost:4000

# Bearer token for Ghoststack API
GHOSTSTACK_API_TOKEN=change-me

# Ghoststack listen port when run embedded (default: 4000)
GHOSTSTACK_API_PORT=4000

# Path to Ghoststack data directory
GHOSTSTACK_DATA_DIR=.ghoststack

# Path to Python binary used by Ghoststack sub-processes
GHOSTSTACK_PYTHON=python3

# Path to system Python binary (fin-scrape runner)
PYTHON_BIN=python3

# Set to true to start in offline mode (simulated responses, no Python bridges needed).
# Flip to false only after installing bridge deps:
#   cd packages/runtime/src/bridges && pip install -r requirements.txt
GHOSTSTACK_OFFLINE_MODE=true

# Bootstrap showcase agents on first start
GHOSTSTACK_BOOTSTRAP_SHOWCASE=false

# Back up data directory on start
GHOSTSTACK_BACKUP_ON_START=false

# Floci internal endpoint (used by packages/runtime floci-client, default: http://localhost:4566)
FLOCI_ENDPOINT=http://localhost:4566

# Nexus API base URL — used by CLI client (default: http://localhost:3000)
NEXUS_API_URL=http://localhost:3000

# Floci (federated inference) URL — leave blank to disable
GHOSTSTACK_FLOCI_URL=

# Fall back to mock responses when Floci is unavailable
GHOSTSTACK_FLOCI_MOCK_FALLBACK=true

# Error if Floci response is not received (overrides mock fallback)
GHOSTSTACK_FLOCI_STRICT=false

# Enable MCP bridge proxy
GHOSTSTACK_MCP_BRIDGE=false

# MCP bridge listen port
GHOSTSTACK_MCP_PORT=4001

# ── Web frontend (Vite) ───────────────────────────────────────────────────────

# Base URL the web app uses to reach the API (proxy target in dev)
VITE_API_URL=http://localhost:3000

# Optional API key baked into the web app build
VITE_API_KEY=

# ── Docs site ─────────────────────────────────────────────────────────────────

# Algolia DocSearch (optional — docs site search)
# ALGOLIA_APP_ID=
# ALGOLIA_API_KEY=
# ALGOLIA_INDEX_NAME=nexus

# ── Signal worker ─────────────────────────────────────────────────────────────

# How often the signal worker polls for new signals (ms, default: 5000)
SIGNAL_WORKER_INTERVAL_MS=5000

# Number of signals processed per poll cycle (default: 10)
SIGNAL_WORKER_BATCH_SIZE=10

# ── Council deliberation ───────────────────────────────────────────────────────

# Model alias used by the council engine (default: nexus/smart → Groq 70b)
# Options: nexus/fast | nexus/smart | nexus/opus | nexus/sonnet | nexus/haiku
#          nexus/gemini | nexus/deepseek | nexus/mistral
COUNCIL_MODEL=nexus/smart

# Max output tokens per council archetype call (default: 4096)
COUNCIL_MAX_TOKENS=4096

# Minimum signal priority that triggers automatic council deliberation (default: high)
# Options: low | medium | high | critical
COUNCIL_MIN_PRIORITY=high

# Max council.deliberate jobs allowed per UTC day — fails open if Redis is down
# Resets automatically at midnight UTC via Redis EXPIREAT (default: 100)
COUNCIL_DAILY_BUDGET=100

# Additional LLM provider keys (council can use any configured provider)
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza...
# DEEPSEEK_API_KEY=sk-...
# MISTRAL_API_KEY=...

# ── Local sidecar router ────────────────────────────────────────────────────────
# Point at any self-hosted OpenAI-compatible router (default port :20128).
# When set, the alias `nexus/omni` routes through it, inheriting its whole provider
# catalog + fallback + compression. Configure the sidecar with your real keys
# (one OpenRouter key alone unlocks 200+ models).
# LOCAL_ROUTER_BASE_URL=http://localhost:20128/v1
# LOCAL_ROUTER_API_KEY=          # the sidecar's own key (blank if none)
# LOCAL_ROUTER_MODEL=auto        # default downstream model; override per-request

# ── Provider OAuth (@nexus/llm-oauth) ──────────────────────────────────────────
# Sanctioned third-party OAuth only. Register your own Google OAuth client
# (console.cloud.google.com → APIs & Services → Credentials),
# add the callback URL, and request the cloud-platform scope. An authed login
# yields a Vertex AI credential routed via the existing VertexDriver.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_CLOUD_PROJECT=          # GCP project Vertex calls bill to
# GOOGLE_CLOUD_REGION=us-central1
# Master key (32 bytes, hex or base64) for the credential vault that encrypts
# OAuth tokens at rest. Reuse NEXUS's existing secret key if you have one.
# LLM_OAUTH_VAULT_KEY=

# ── Search orchestrator ────────────────────────────────────────────────────────

# Chroma vector DB endpoint (enables ChromaSearchStrategy in search-orchestrator)
# Leave blank to fall back to mock strategies in dev
# CHROMA_URL=http://chroma:8000

# Chroma collection name (default: nexus)
# CHROMA_COLLECTION=nexus

# ── HuggingFace corpus publisher ──────────────────────────────────────────────

# HF Hub write-access token (enables HuggingFacePublisher for POST /corpus/flush)
# Generate at: https://huggingface.co/settings/tokens
# HF_TOKEN=hf_...

# Target HuggingFace dataset repo (default: nexus/research)
# HF_REPO_ID=nexus/research

# ── Domain feed pollers ────────────────────────────────────────────────────────

# OpenWeatherMap API key (enables weather feed polling every 5 min)
# Get at: https://openweathermap.org/api
# OPENWEATHER_API_KEY=...

# City to poll for weather data (default: London)
# OPENWEATHER_CITY=London

# NewsAPI key (enables news feed polling every 5 min)
# Get at: https://newsapi.org/register
# NEWS_API_KEY=...

# ── RSS ingestion ──────────────────────────────────────────────────────────────

# Comma-separated list of RSS/Atom feed URLs polled every 15 min by the worker
# RSS_FEED_URLS=https://feeds.bbci.co.uk/news/rss.xml,https://rss.nytimes.com/services/xml/rss/nyt/World.xml

# ── Brief engine ───────────────────────────────────────────────────────────────

# HMAC-SHA256 signing key for BriefSigner (min 32 chars recommended)
# Generate: openssl rand -hex 32
# BRIEF_SIGNING_KEY=change-me-dev-signing-key

# ── Observation providers ──────────────────────────────────────────────────────

# LLM driver for structured observation extraction (format: provider/model)
# When set, LlmObservationProvider is used as primary; falls back to MockObservationProvider
# Example values: groq/llama-3.3-70b | groq/llama-3.1-8b-instant | claude/claude-opus-4-5
# NEXUS_OBSERVATION_DRIVER=groq/llama-3.3-70b

# ── Domain forecast ────────────────────────────────────────────────────────────

# OpenWeatherMap API key for OpenWeatherForecastHandler (separate from OPENWEATHER_API_KEY)
# When set, createProductionGateway() wires real weather forecasts for the "geo" domain
# OWM_API_KEY=...

# City used by OpenWeatherForecastHandler (default: London)
# OWM_CITY=London

# ── MCP OAuth ──────────────────────────────────────────────────────────────────

# OAuth 2.0 client credentials for McpOAuthProvider
# MCP_OAUTH_CLIENT_ID=your-client-id
# MCP_OAUTH_CLIENT_SECRET=your-client-secret

# OAuth token endpoint (used by McpServer.requireOAuth())
# MCP_OAUTH_TOKEN_URL=https://auth.example.com/oauth/token

# Space-separated OAuth scopes requested during token exchange
# MCP_OAUTH_SCOPES=mcp:tools mcp:resources

# ── SPECTRE (apps/spectre) ─────────────────────────────────────────────────────

# URL of the running Nexus API (apps/api). Leave empty to proxy via Vite dev server.
# VITE_API_URL=http://localhost:3000

# Nexus API key — same value as NEXUS_API_KEY above.
# VITE_API_KEY=your-nexus-api-key

# ── CODE-REPL / SANDBOX (packages/code-repl, /api/v1/code-repl) ──────────────────
# Sandboxed execution runs each request in a throwaway Docker container with a
# hard memory cap, no network, dropped capabilities and no-new-privileges.
# Requires a Docker daemon reachable from the API process (docker.sock). If Docker
# is unavailable the API falls back to a no-op mock executor.

# Hard memory cap per execution (default: 512m). Swap is disabled so this is a hard limit.
# REPL_MEMORY_LIMIT=512m

# CPU cap per execution in cores (default: 0.5)
# REPL_CPU_LIMIT=0.5

# Default wall-clock timeout per execution in ms (default: 10000, max 300000)
# REPL_TIMEOUT_MS=10000

# Max concurrent kernel sessions (default: 20)
# REPL_MAX_SESSIONS=20

# Container image for the "shell" language — arbitrary Linux commands (default: alpine:3.20).
# The shell language additionally runs as non-root (65534:65534) with a read-only
# rootfs and a 64MB writable /tmp tmpfs.
# SANDBOX_SHELL_IMAGE=alpine:3.20

# ── TELEGRAM BOT (apps/api POST /bots/telegram/webhook, @nexus/bots) ─────────────
# Bot API token from @BotFather.
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Secret token to register with setWebhook and verify on each request (recommended).
# Set the webhook with:
#   curl "https://api.telegram.org/bot$TELEGRAM_BOT_TOKEN/setWebhook" \
#     -d "url=https://<your-host>/bots/telegram/webhook" \
#     -d "secret_token=$TELEGRAM_WEBHOOK_SECRET"
# TELEGRAM_WEBHOOK_SECRET=a-long-random-string

# Bot @username (without @) — enables "mention" trigger mode in group chats.
# TELEGRAM_BOT_USERNAME=my_nexus_bot

# ── WORKER THROUGHPUT (apps/worker BullMQ concurrency) ───────────────────────────
# Concurrent jobs per priority queue. Defaults: high=4, medium=8, low=2.
# Scale up on larger nodes; scale down on constrained ones. Horizontal scaling:
# run multiple worker pods — BullMQ coordinates via Redis.
# WORKER_CONCURRENCY_HIGH=4
# WORKER_CONCURRENCY_MEDIUM=8
# WORKER_CONCURRENCY_LOW=2
