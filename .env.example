# SPDX-License-Identifier: Apache-2.0
# ─────────────────────────────────────────────────────────────────────────────
# NEXUS — environment variable reference
#
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────────────────────────

NODE_ENV=development

# PostgreSQL connection string (used by @nexus/db, apps/api, services/ingest)
DATABASE_URL=postgresql://nexus:nexus_dev_password@localhost:5432/nexus

# Redis connection string (used by apps/api BullMQ queues, worker)
REDIS_URL=redis://localhost:6379

# ── API Server ────────────────────────────────────────────────────────────────

# Fastify listen port (default: 3000)
PORT=3000

# Fastify listen host (default: 0.0.0.0)
HOST=0.0.0.0

# Comma-separated allowed CORS origins (default: *)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Log level: trace | debug | info | warn | error | fatal (default: info)
LOG_LEVEL=info

# Log format: json | pretty (default: pretty in dev)
LOG_FORMAT=pretty

# Log file path (optional; if unset logs go to stdout only)
# LOG_FILE=/var/log/nexus/api.log

# ── Authentication ────────────────────────────────────────────────────────────

# Master API key required in Authorization: Bearer <key> header for all routes
# Generate with: openssl rand -hex 32
NEXUS_API_KEY=change-me-dev-api-key

# Separate audit-log signing key (used by GET /audit/verify)
# Generate with: openssl rand -hex 32
NEXUS_AUDIT_KEY=change-me-dev-audit-key

# Ingest-only key for POST /ingest/* (can be same as NEXUS_API_KEY)
NEXUS_INGEST_API_KEY=change-me-dev-ingest-key

# ── AI / LLM providers ────────────────────────────────────────────────────────

# Groq — used by council deliberation engine
GROQ_API_KEY=gsk_...

# Tavily — used by deep-research tasks
TAVILY_API_KEY=tvly-...

# ── Ghoststack adapter ────────────────────────────────────────────────────────

# Base URL of the Ghoststack API (used by packages/adapters ghoststack adapter)
GHOSTSTACK_API_URL=http://localhost:4000

# Bearer token for Ghoststack API
GHOSTSTACK_API_TOKEN=change-me

# Ghoststack listen port when run embedded (default: 4000)
GHOSTSTACK_API_PORT=4000

# Path to Ghoststack data directory
GHOSTSTACK_DATA_DIR=.ghoststack

# Path to Python binary used by Ghoststack sub-processes
GHOSTSTACK_PYTHON=python3

# Path to system Python binary (fin-scrape runner)
PYTHON_BIN=python3

# Set to true to start in offline mode (no outbound requests)
GHOSTSTACK_OFFLINE_MODE=false

# Bootstrap showcase agents on first start
GHOSTSTACK_BOOTSTRAP_SHOWCASE=false

# Back up data directory on start
GHOSTSTACK_BACKUP_ON_START=false

# Floci (federated inference) URL — leave blank to disable
GHOSTSTACK_FLOCI_URL=

# Fall back to mock responses when Floci is unavailable
GHOSTSTACK_FLOCI_MOCK_FALLBACK=true

# Error if Floci response is not received (overrides mock fallback)
GHOSTSTACK_FLOCI_STRICT=false

# Enable MCP bridge proxy
GHOSTSTACK_MCP_BRIDGE=false

# MCP bridge listen port
GHOSTSTACK_MCP_PORT=4001

# ── Web frontend (Vite) ───────────────────────────────────────────────────────

# Base URL the web app uses to reach the API (proxy target in dev)
VITE_API_URL=http://localhost:3000

# Optional API key baked into the web app build
VITE_API_KEY=

# ── Docs site ─────────────────────────────────────────────────────────────────

# Algolia DocSearch (optional — docs site search)
# ALGOLIA_APP_ID=
# ALGOLIA_API_KEY=
# ALGOLIA_INDEX_NAME=nexus
